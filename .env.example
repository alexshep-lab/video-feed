# Semicolon-separated absolute paths to scan for videos.
# Windows example:
VIDEOFEED_LIBRARY_DIRS_RAW=G:\Path\To\video_feed\videos;D:\MyVideoArchive

# Optional. Where WMV/AVI → MP4 conversions are written. Defaults to
# <media_dir>/converted. Point at a big-enough drive — converted MP4s
# can grow to hundreds of GB.
# VIDEOFEED_CONVERTED_DIR_RAW=L:\Prvt\Converted

# Optional. Encoder: auto (NVENC if present) | cpu | nvenc.
# VIDEOFEED_ENCODER_MODE=auto

# Optional. Where FHD-compressed originals are archived. Use a drive
# other than the library's drive if you actually want to free space.
# VIDEOFEED_BIG_ARCHIVE_DIR=L:\Prvt\big

# Optional. Semicolon-separated CORS origins. Default = loopback-only
# (safe). Set to "*" to allow any origin; credentials are then
# automatically disabled. Do not expose to the public internet.
# VIDEOFEED_CORS_ORIGINS_RAW=http://localhost:7999;http://192.168.1.10:7999
